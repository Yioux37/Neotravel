# --- Front NeoTravel : proxy vers n8n ---
# URL du webhook n8n qui déclenche le workflow "Agent IA".
# Variable SERVEUR uniquement (pas de préfixe NEXT_PUBLIC_) : l'URL ne doit
# jamais être exposée au navigateur.
N8N_WEBHOOK_URL=https://votre-instance.n8n.cloud/webhook/neotravel-chat

# Secret partagé : envoyé dans l'en-tête x-webhook-secret, vérifié côté n8n
# pour rejeter les appels qui ne viennent pas de ce front. Optionnel mais
# fortement recommandé en production.
N8N_WEBHOOK_SECRET=remplacez-par-une-chaine-aleatoire-longue
