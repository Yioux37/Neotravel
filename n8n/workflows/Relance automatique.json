        "jsCode": "const today = new Date();\ntoday.setHours(0, 0, 0, 0);\n\nconst items = $input.all();\nconst candidats = [];\n\nfor (const item of items) {\n  const d = item.json;\n  if (!d.date_envoi) continue;\n\n  const dateEnvoi = new Date(d.date_envoi);\n  dateEnvoi.setHours(0, 0, 0, 0);\n  const joursDepuisEnvoi = Math.floor((today - dateEnvoi) / 86400000);\n\n  if (joursDepuisEnvoi >= 2) {\n    candidats.push({ json: { ...d, jours_depuis_envoi: joursDepuisEnvoi } });\n  }\n}\n\nif (candidats.length === 0) {\n  return [{ json: { _aucun_candidat: true, count: 0 } }];\n}\n\nreturn candidats;"
