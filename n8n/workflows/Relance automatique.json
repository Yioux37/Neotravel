      "parameters": {
        "jsCode": "const now = new Date();\nconst items = $input.all();\nconst candidats = [];\n\nfor (const item of items) {\n  const d = item.json;\n  if (!d.created_at || !d.email) continue;\n\n  const created = new Date(d.created_at);\n  const minutesPassed = (now - created) / 60000;\n  const nbRelances = Number(d.nb_relances_form || 0);\n\n  const doitRelancer =\n    (nbRelances === 0 && minutesPassed >= 5) ||\n    (nbRelances === 1 && minutesPassed >= 10);\n\n  if (doitRelancer) {\n    candidats.push({ json: { ...d, minutes_passed: Math.floor(minutesPassed) } });\n  }\n}\n\nif (candidats.length === 0) return [{ json: { _aucun_candidat: true } }];\nreturn candidats;"
      },
