    {
      "parameters": {
        "jsCode": "const devis = $('B - Loop: traiter 1 devis à la fois').first().json;\nconst demande = $input.first()?.json || {};\n\nconst today = new Date();\ntoday.setHours(0, 0, 0, 0);\n\nconst dateEnvoi = new Date(devis.date_envoi);\ndateEnvoi.setHours(0, 0, 0, 0);\nconst jours = devis.jours_depuis_envoi || Math.floor((today - dateEnvoi) / 86400000);\n\nconst nbRelances = Number(devis.nb_relances || 0);\nconst urgence = (demande.urgence || 'standard').toLowerCase();\nconst isUrgent = urgence === 'urgent' || urgence === 'prioritaire';\n\nlet action = 'skip';\nif (nbRelances >= 2) {\n  action = 'cloturer';\n} else if (isUrgent) {\n  if (nbRelances === 0 && jours >= 2) action = 'relancer';\n  else if (nbRelances === 1 && jours >= 4) action = 'cloturer';\n} else {\n  if (nbRelances === 0 && jours >= 3) action = 'relancer';\n  else if (nbRelances === 1 && jours >= 7) action = 'relancer';\n}\n\nconst ref = 'NEO-' + (devis.session_id || '000000').slice(-6).toUpperCase();\nconst nomProspect = demande.nom_prospect || 'Client';\nconst villeDepart = demande.ville_depart || '—';\nconst villeDest = demande.ville_destination || '—';\nconst montantTtc = Number(devis.montant_ttc || 0).toLocaleString('fr-FR', { minimumFractionDigits: 2 });\nconst numRelance = nbRelances + 1;\n\nconst subjectRelance = numRelance === 1\n  ? `[Rappel] Votre devis Neotravel ${ref} est en attente`\n  : `[Dernière relance] Votre devis Neotravel ${ref}`;\n\nconst emailHtml = `<!DOCTYPE html><html lang=\"fr\"><head><meta charset=\"UTF-8\"><style>body{font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px;color:#1F2937;}.header{background:linear-gradient(135deg,#1E40AF,#3B82F6);color:white;padding:24px;border-radius:10px 10px 0 0;}.logo{font-size:20px;font-weight:800;}.logo span{color:#FDE68A;}.body{background:#F9FAFB;padding:24px;border:1px solid #E5E7EB;}.devis-card{background:white;border:1px solid #E5E7EB;border-radius:8px;padding:16px;margin:16px 0;}.price{font-size:28px;font-weight:800;color:#1E40AF;}.btn{display:block;background:#F59E0B;color:white;text-align:center;padding:12px 20px;border-radius:8px;text-decoration:none;font-weight:700;font-size:14px;margin:20px 0;}.footer{background:#1F2937;color:#9CA3AF;padding:16px;border-radius:0 0 10px 10px;font-size:11px;text-align:center;}</style></head><body><div class=\"header\"><div class=\"logo\">Neo<span>travel</span></div><div style=\"opacity:.9;font-size:13px;margin-top:4px;\">Relance ${numRelance}/2 · ${ref}</div></div><div class=\"body\"><p>Bonjour ${nomProspect},</p><br><p>Nous revenons vers vous concernant votre devis de transport en autocar <strong>${villeDepart} → ${villeDest}</strong>.</p><div class=\"devis-card\"><div style=\"font-size:12px;color:#9CA3AF;\">Référence devis</div><div style=\"font-weight:700;color:#1E40AF;\">${ref}</div><div style=\"font-size:12px;color:#9CA3AF;margin-top:8px;\">Montant TTC</div><div class=\"price\">${montantTtc} €</div></div>${numRelance === 2 ? '<p style=\"color:#DC2626;font-weight:600;\">Ce devis expire prochainement. Dernier rappel avant clôture automatique.</p>' : '<p>Ce devis vous attend toujours — n\\'hésitez pas à revenir vers nous.</p>'}<a href=\"mailto:contact@neotravel.fr?subject=Réponse devis ${ref}\" class=\"btn\">Répondre à ce devis</a></div><div class=\"footer\">Neotravel SAS · contact@neotravel.fr</div></body></html>`;\n\nreturn [{\n  json: {\n    action, session_id: devis.session_id, devis_id: devis.id, demande_id: demande.id,\n    email_subject: subjectRelance, email_html: emailHtml,\n    nb_relances_actuel: nbRelances, nb_relances_nouveau: nbRelances + 1,\n    ref, urgence, jours_depuis_envoi: jours\n  }\n}];"
      },
