    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst nbRelances = Number(d.nb_relances_form || 0);\nconst numRelance = nbRelances + 1;\n\nconst nomProspect = d.nom_prospect || 'Bonjour';\nconst villeDepart = d.ville_depart || '';\nconst villeDest = d.ville_destination || '';\nconst trajet = (villeDepart && villeDest) ? `${villeDepart} → ${villeDest}` : 'votre trajet en autocar';\n\nconst isFirst = numRelance === 1;\nconst subject = isFirst\n  ? 'Votre demande de devis Neotravel est en attente'\n  : '[Rappel] Finalisez votre demande de devis Neotravel';\n\nconst accroche = isFirst\n  ? 'Il semblerait que vous n\\'ayez pas terminé votre demande de devis.'\n  : 'Ceci est notre dernier rappel — votre demande vous attend toujours.';\n\nconst emailHtml = `<!DOCTYPE html><html lang=\"fr\"><head><meta charset=\"UTF-8\"><style>body{font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px;color:#1F2937;}.header{background:linear-gradient(135deg,#1E40AF,#3B82F6);color:white;padding:24px;border-radius:10px 10px 0 0;}.logo{font-size:20px;font-weight:800;}.logo span{color:#FDE68A;}.body{background:#F9FAFB;padding:24px;border:1px solid #E5E7EB;}.btn{display:block;background:#1E40AF;color:white;text-align:center;padding:14px 20px;border-radius:8px;text-decoration:none;font-weight:700;font-size:14px;margin:20px 0;}.footer{background:#1F2937;color:#9CA3AF;padding:16px;border-radius:0 0 10px 10px;font-size:11px;text-align:center;}</style></head><body><div class=\"header\"><div class=\"logo\">Neo<span>travel</span></div><div style=\"opacity:.9;font-size:13px;margin-top:4px;\">Relance formulaire ${numRelance}/2</div></div><div class=\"body\"><p>Bonjour ${nomProspect},</p><br><p>${accroche}</p><p>Vous aviez commencé une demande de devis pour <strong>${trajet}</strong>. Il ne vous reste que quelques instants pour obtenir votre tarif personnalisé.</p><a href=\"https://YOUR-APP.vercel.app/devis\" class=\"btn\">Finaliser ma demande de devis</a>${numRelance === 2 ? '<p style=\"color:#DC2626;font-size:13px;\">Cette relance est la dernière. Sans réponse, votre demande sera clôturée.</p>' : ''}</div><div class=\"footer\">Neotravel SAS · contact@neotravel.fr</div></body></html>`;\n\nreturn [{ json: { ...d, email_subject: subject, email_html: emailHtml, nb_relances_form_nouveau: nbRelances + 1 } }];"
      },
